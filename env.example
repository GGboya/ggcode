# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ggcode
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=1h

# JWT配置
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=24h
JWT_ISSUER=ggcode

# 服务器配置
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s

# 评测系统配置
JUDGE_DATA_ROOT=/judge/data
JUDGE_WORKSPACE_ROOT=/tmp/ggcode_workspace
JUDGE_MAX_WORKERS=10
JUDGE_DEFAULT_TIME_LIMIT=5
JUDGE_DEFAULT_MEMORY_LIMIT=128
JUDGE_CLEANUP_INTERVAL=1h

# 安全配置
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
MAX_REQUEST_SIZE=10485760
ALLOWED_ORIGINS=*
ENABLE_CORS=true

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=10
LOG_MAX_AGE=7
LOG_COMPRESS=true 