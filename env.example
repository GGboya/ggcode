# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ggcode

# JWT密钥
JWT_SECRET=your-secret-key

# 服务器配置
SERVER_PORT=8080

# TLS/HTTPS配置
ENABLE_TLS=false
TLS_CERT_FILE=
TLS_KEY_FILE=

# 使用Let's Encrypt时的示例配置：
# ENABLE_TLS=true
# TLS_CERT_FILE=/etc/letsencrypt/live/your-domain.com/fullchain.pem
# TLS_KEY_FILE=/etc/letsencrypt/live/your-domain.com/privkey.pem 